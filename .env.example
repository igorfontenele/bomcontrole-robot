# ============================================================================
# BomControle — API pública (ApiKey)
# ============================================================================
BOMCONTROLE_API_KEY=cole_aqui_a_apikey
BOMCONTROLE_BASE_URL=https://apinewintegracao.bomcontrole.com.br/integracao

# ============================================================================
# BomControle — Login do browser (usado pelo Selenium pra capturar JWT)
# ============================================================================
BOMCONTROLE_LOGIN=pauladepaula@finaconcontabil.com.br
BOMCONTROLE_SENHA=cole_aqui_a_senha
BOMCONTROLE_SUBDOMINIO=finacon
BOMCONTROLE_TENANT_ID=29860
BOMCONTROLE_BASE_URL_INTERNO=https://apinew.bomcontrole.com.br/api

# ============================================================================
# GitHub Releases (destino do zip)
# ============================================================================
# Personal Access Token com escopo "repo" (classic) ou "contents: write" (fine-grained)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# owner/repo — ex: igorfontenele/bomcontrole-robot
GITHUB_REPO=owner/repo

# ============================================================================
# Resend (envio de email)
# ============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=pauladepaula@finaconcontabil.com.br

# ============================================================================
# Execução
# ============================================================================
# Se "anterior", processa o mês anterior ao atual. Se "AAAA-MM", processa esse mês fixo.
MES_REFERENCIA=anterior

# Modo headless do Chrome (true no Railway, false pra debug local)
HEADLESS=true
